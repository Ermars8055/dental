DB_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32

# ─── Auth ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_64

# ─── URLs (set to your actual domain) ─────────────────────────
